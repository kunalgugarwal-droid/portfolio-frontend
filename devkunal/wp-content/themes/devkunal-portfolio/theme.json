{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{ "color": "#f5efe6", "name": "Canvas", "slug": "base" },
				{ "color": "#111827", "name": "Ink", "slug": "contrast" },
				{ "color": "#c46b48", "name": "Terracotta", "slug": "accent-1" },
				{ "color": "#1f4d4d", "name": "Deep Teal", "slug": "accent-2" },
				{ "color": "#e3b552", "name": "Sun", "slug": "accent-3" },
				{ "color": "#5f6b76", "name": "Muted", "slug": "accent-4" },
				{ "color": "#fffaf4", "name": "Surface", "slug": "accent-5" }
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1240px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "name": "Tiny", "size": "10px", "slug": "20" },
				{ "name": "X-Small", "size": "20px", "slug": "30" },
				{ "name": "Small", "size": "32px", "slug": "40" },
				{ "name": "Regular", "size": "clamp(32px, 5vw, 56px)", "slug": "50" },
				{ "name": "Large", "size": "clamp(42px, 7vw, 88px)", "slug": "60" },
				{ "name": "X-Large", "size": "clamp(54px, 8vw, 112px)", "slug": "70" }
			]
		},
		"typography": {
			"fluid": true,
			"defaultFontSizes": false,
			"fontFamilies": [
				{ "name": "Manrope Local", "slug": "manrope-local", "fontFamily": "\"Manrope Local\", sans-serif" },
				{ "name": "Beiruti Local", "slug": "beiruti-local", "fontFamily": "\"Beiruti Local\", sans-serif" }
			],
			"fontSizes": [
				{ "name": "Small", "size": "0.95rem", "slug": "small" },
				{ "name": "Medium", "size": "1.05rem", "slug": "medium" },
				{ "name": "Large", "size": "1.25rem", "slug": "large" },
				{ "name": "X-Large", "size": "clamp(1.9rem, 3vw, 2.7rem)", "slug": "x-large" },
				{ "name": "XX-Large", "size": "clamp(3.2rem, 7vw, 6rem)", "slug": "xx-large" }
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "1.25rem",
			"padding": {
				"left": "var:preset|spacing|40",
				"right": "var:preset|spacing|40"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|manrope-local",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "400",
			"lineHeight": "1.65"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|beiruti-local",
					"fontWeight": "600",
					"letterSpacing": "-0.04em",
					"lineHeight": "0.98"
				}
			},
			"button": {
				"color": {
					"background": "var:preset|color|accent-1",
					"text": "var:preset|color|accent-5"
				},
				"border": {
					"radius": "999px"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			}
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header", "title": "Header" },
		{ "area": "footer", "name": "footer", "title": "Footer" }
	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"postTypes": [ "page" ],
			"title": "Page No Title"
		}
	]
}
